# Copy this file to .env (do not commit .env)

# MySQL container init
MYSQL_ROOT_PASSWORD=password123
MYSQL_DATABASE=jmoney

# API DB connection settings (used by server/settings/settings.py)
# You can either set DATABASE_URL, or set DATABASE_* fields below.
# Example URL (note: driver is mysqlclient):
# DATABASE_URL=mysql://root:password123@jmoney_db:3306/jmoney

DATABASE_URL=
DATABASE_USER=root
DATABASE_PASSWORD=password123
DATABASE_HOST=jmoney_db
DATABASE_PORT=3306
DATABASE_NAME=jmoney

# How long the API container waits for the DB TCP port to accept connections
DB_WAIT_TIMEOUT=60
